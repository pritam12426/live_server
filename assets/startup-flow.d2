direction: down
title: "Server Startup Sequence (Optimized)"

# ── Steps ─────────────────────────────────────────────────

step1: {
  label: "1. main() start"
  shape: oval
  style: {
	fill: "#e8f0fc"
	stroke: "#1e50a2"
	font-color: "#1e50a2"
  }
}

step2: {
  label: "2. argp_parse()\nparse CLI flags"
  style: {
	fill: "#e8f0fc"
	stroke: "#1e50a2"
	font-color: "#1e50a2"
  }
}

step3: {
  label: "3. log_init(NULL)\nlock-free ring buffer\nspawns consumer thread"
  style: {
	fill: "#faf6d8"
	stroke: "#8a7a0f"
	font-color: "#8a7a0f"
  }
}

step4: {
  label: "4. Build ServerConfig\nfrom parsed args"
  style: {
	fill: "#e8f0fc"
	stroke: "#1e50a2"
	font-color: "#1e50a2"
  }
}

step5: {
  label: "5. server_run(&cfg)"
  shape: oval
  style: {
	fill: "#faeeda"
	stroke: "#854f0b"
	font-color: "#854f0b"
  }
}

step6: {
  label: "6. Install signal handlers\nSIGINT/SIGTERM → g_shutdown\nSIGPIPE → ignore"
  style: {
	fill: "#faeeda"
	stroke: "#854f0b"
	font-color: "#854f0b"
  }
}

step7: {
  label: "7. make_listener()\ngetaddrinfo → socket\nbind → listen(128)"
  style: {
	fill: "#faeeda"
	stroke: "#854f0b"
	font-color: "#854f0b"
  }
}

decision_lr: {
  label: "8. Live reload enabled?"
  shape: diamond
  style: {
	fill: "#faf6d8"
	stroke: "#8a7a0f"
	font-color: "#8a7a0f"
  }
}

step8a: {
  label: "   livereload_start()\n   hash map SSE registry\n   watcher_create() → watcher_start()\n   (background thread)"
  style: {
	fill: "#dff5f2"
	stroke: "#0f7a6e"
	font-color: "#0f7a6e"
  }
}

step9: {
  label: "9. thread_pool_create(N)\n   N worker threads started\n   waiting on not_empty"
  style: {
	fill: "#faeeda"
	stroke: "#854f0b"
	font-color: "#854f0b"
  }
}

step9b: {
  label: "10. ratelimit_create()\n   if max_conns_per_ip > 0\ndynamic hash table"
  style: {
	fill: "#faeeda"
	stroke: "#854f0b"
	font-color: "#854f0b"
  }
}

step10: {
  label: "11. header_cache_init()\npre-compute Date/Server/Connection\nupdates once/sec"
  style: {
	fill: "#e1f5ee"
	stroke: "#0f6e56"
	font-color: "#0f6e56"
  }
}

step11: {
  label: "12. Log startup info\nURL, pool size, keep-alive\nrate limit, LR mode"
  style: {
	fill: "#faf6d8"
	stroke: "#8a7a0f"
	font-color: "#8a7a0f"
  }
}

decision_browser: {
  label: "13. Browser flag set?"
  shape: diamond
  style: {
	fill: "#faf6d8"
	stroke: "#8a7a0f"
	font-color: "#8a7a0f"
  }
}

step13a: {
  label: "   fork() + execlp()\n   browser URL"
  style: {
	fill: "#ffffff"
	stroke: "#d8d7d2"
	font-color: "#6b6a66"
  }
}

step14: {
  label: "14. while (!g_shutdown)\n   accept() loop"
  shape: oval
  style: {
	fill: "#e8f0fc"
	stroke: "#1e50a2"
	font-color: "#1e50a2"
  }
}

# ── Edges ─────────────────────────────────────────────────

step1 -> step2
step2 -> step3
step3 -> step4
step4 -> step5
step5 -> step6
step6 -> step7
step7 -> decision_lr
decision_lr -> step8a: yes
decision_lr -> step9: no
step8a -> step9
step9 -> step9b
step9b -> step10
step10 -> step11
step11 -> decision_browser
decision_browser -> step13a: yes
decision_browser -> step14: no
step13a -> step14
