  style: {
	fill: "#f6f5f2"
	stroke: "#dedcd6"
	stroke-dash: 5
	font-color: "#8a8983"
	font-size: 12
	opacity: 0.6
  }

  http: {
	label: "http.c\nRequest parser\nbuffered header read"
	style: { fill: "#e1f5ee"; stroke: "#0f6e56"; font-color: "#0f6e56" }
  }
  response: {
	label: "response.c\nResponse builder\nerror pages, redirects"
