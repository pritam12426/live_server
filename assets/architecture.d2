# ── Edges ─────────────────────────────────────────────────

"Entry & Config".main -> "Server Core".server: ServerConfig
"Entry & Config".main -> Diagnostics.log: log_init()
"Entry & Config".main -> "Entry & Config".project_config
"Entry & Config".main -> "Entry & Config".types

"Server Core".server -> "Server Core".transport: Transport*
"Server Core".server -> "Server Core".thread_pool: submit tasks
"Server Core".server -> "Server Core".ratelimit: check/leave
"Server Core".server -> "HTTP Protocol".http: parse request
"Server Core".server -> "HTTP Protocol".auth: check creds
"Server Core".server -> "Live Reload".livereload: start/stop
"Server Core".server -> "File Serving".file: dispatch serve
"Server Core".server -> "HTTP Protocol".header_cache: build headers

"HTTP Protocol".http -> "Server Core".transport: read raw headers
"HTTP Protocol".response -> "Server Core".transport: write response
"File Serving".file -> "HTTP Protocol".response: send_file()
"File Serving".file -> "HTTP Protocol".mime: mime_from_path()
"File Serving".file -> "HTTP Protocol".http: read HttpRequest
"File Serving".file -> Utilities.thread_buffer: get_buffer()

"Live Reload".livereload -> "Live Reload".watcher: create / start
"Live Reload".livereload -> "Server Core".transport: SSE write

Diagnostics.log -> "Server Core".server
Diagnostics.log -> "File Serving".file
Diagnostics.log -> "HTTP Protocol".http
Diagnostics.log -> "Server Core".transport
Diagnostics.log -> "Server Core".thread_pool
Diagnostics.log -> "Live Reload".livereload
Diagnostics.log -> "Server Core".ratelimit
Diagnostics.log -> "HTTP Protocol".auth
Diagnostics.log -> "HTTP Protocol".mime
