direction: down
title: "live-server — Module Architecture"

# ── Clusters ──────────────────────────────────────────────

"Entry & Config": {
  style: {
	fill: "#f6f5f2"
	stroke: "#dedcd6"
	stroke-dash: 5
	font-color: "#8a8983"
	font-size: 12
	opacity: 0.6
  }

  main: {
	label: "main.c\nargp CLI parser"
	style: { fill: "#e8f0fc"; stroke: "#1e50a2"; font-color: "#1e50a2" }
  }
  project_config: {
	label: "project_config.h\nVersion, name, URL"
	style: { fill: "#ffffff"; stroke: "#d8d7d2"; font-color: "#6b6a66" }
  }
  types: {
	label: "types.h\nLivereloadMode"
	style: { fill: "#ffffff"; stroke: "#d8d7d2"; font-color: "#6b6a66" }
  }
}

"Server Core": {
  style: {
	fill: "#f6f5f2"
	stroke: "#dedcd6"
	stroke-dash: 5
	font-color: "#8a8983"
	font-size: 12
	opacity: 0.6
  }

  server: {
	label: "server.c\nAccept loop, signal handling\nthread dispatch"
	style: { fill: "#faeeda"; stroke: "#854f0b"; font-color: "#854f0b" }
  }
  transport: {
	label: "transport.c\nOpaque socket I/O\npartial write, writev()"
	style: { fill: "#faeeda"; stroke: "#854f0b"; font-color: "#854f0b" }
  }
  thread_pool: {
	label: "thread_pool.c\nFixed-size pool\ncircular work queue"
	style: { fill: "#faeeda"; stroke: "#854f0b"; font-color: "#854f0b" }
  }
  ratelimit: {
	label: "ratelimit.c\nPer-IP rate limiter\ndynamic hash table"
	style: { fill: "#faeeda"; stroke: "#854f0b"; font-color: "#854f0b" }
  }
}

